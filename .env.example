# environment
ENVIRONMENT=local

# legal documents
CURRENT_TERMS_VERSION=1
CURRENT_PRIVACY_VERSION=1

# external apis
GOOGLE_BOOKS_API_KEY=AIzaSyA1...
# optional -- Google login/linking becomes unavailable (503) if this isn't set
GOOGLE_OAUTH_CLIENT_ID=123456789...
# optional -- Gravatar linking (link only, not a login method) becomes unavailable (503)
# if both aren't set together
GRAVATAR_OAUTH_CLIENT_ID=123456
GRAVATAR_OAUTH_CLIENT_SECRET=AIzaSyA1...

# security and jwt
JWT_SECRET_KEY=9a2f81c4e3b2a1...
JWT_ALGORITHM=HS256
# optional -- defaults to 15min (production); can be increased in dev for convenience
ACCESS_TOKEN_EXPIRY_MINUTES=15
# optional -- defaults to 60 days; also sets the refresh token's httpOnly cookie Max-Age
REFRESH_TOKEN_EXPIRY_DAYS=60

# infrastructure / databases
MONGODB_URL=mongodb://localhost:27017/
MONGODB_DB_NAME=canterlot_db
REDIS_URL=redis://localhost:6379/0

# rate limiting -- both optional, values below are the defaults
CLUB_OWNERSHIP_ACTION_RATE_LIMIT=10
CLUB_OWNERSHIP_ACTION_RATE_LIMIT_WINDOW_SECONDS=3600
