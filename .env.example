# ambiente
ENVIRONMENT=local

# apis externas
GOOGLE_BOOKS_API_KEY=AIzaSyA1...
# opcional -- login/link via Google fica indisponível (503) se esta não for definida
GOOGLE_OAUTH_CLIENT_ID=123456789...

# segurança e jwt
JWT_SECRET_KEY=9a2f81c4e3b2a1...
JWT_ALGORITHM=HS256
# opcional -- padrão de 15min (produção); pode ser aumentado em dev por conveniência
ACCESS_TOKEN_EXPIRY_MINUTES=15
# opcional -- padrão de 60 dias; também define o Max-Age do cookie httpOnly do refresh token
REFRESH_TOKEN_EXPIRY_DAYS=60

# infraestrutura / bancos
MONGODB_URL=mongodb://localhost:27017/
MONGODB_DB_NAME=canterlot_db
REDIS_URL=redis://localhost:6379/0

# rate limiting -- ambos opcionais, valores abaixo são o padrão
CLUB_OWNERSHIP_ACTION_RATE_LIMIT=10
CLUB_OWNERSHIP_ACTION_RATE_LIMIT_WINDOW_SECONDS=3600