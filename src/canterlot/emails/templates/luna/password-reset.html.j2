{% extends "luna/layout.html.j2" %}
{% import "macros.html.j2" as ui %}

{% block content %}
  {{ ui.salutation(recipient_name, punc=".") }}

  {% call ui.text_block() %}
    We received a request to reset the password for your {{ ui.canterlot() }} account. Use the code below to choose a new password.
  {% endcall %}

  {{ ui.code_box(code) }}

  {% call ui.alert_box(type="warning") %}
    The code expires in 1 hour. If you didn't request this reset, ignore this email — your password remains the same and no action is needed.
  {% endcall %}

  {{ ui.action_button(action_url, "Reset password") }}
{% endblock %}